[
  {
    "id": "dawn-will-come",
    "title": "天总会亮",
    "author": "晚睐",
    "category": "poetry",
    "date": "2026-05-19",
    "form": "自由诗",
    "language": "zh",
    "lines": [
      "一个失声者",
      "跌进黑夜里",
      "企图起舞",
      "他挥动衣袖 似有风起",
      "转呀转呀~",
      "渐渐在这夜里沉溺",
      "冷风沁凉 清醒而悲戚",
      "从一个漩涡奔向另一个漩涡里",
      "他疲于循风而栖",
      "却也害怕太阳升起"
    ]
  },
  {
    "id": "clear-day",
    "title": "固执的云",
    "author": "晚睐",
    "category": "poetry",
    "date": "2026-05-19",
    "form": "自由诗",
    "language": "zh",
    "lines": [
      "晴朗的一天",
      "温风沐阳",
      "也总爱在傍晚时寻找月亮",
      "发现一朵固执的云",
      "不愿沉降",
      "像我一样",
      "像我一样倔强",
      "",
      "树影摇晃、岁月悠长，她在何方",
      "我的念想在月色中撒下灵魂和命运的谎",
      "可你要穿越多少沼泽",
      "才能到这里",
      "与我一同欣赏",
      "这满目春光"
    ]
  }
]
